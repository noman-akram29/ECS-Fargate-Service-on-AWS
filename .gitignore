# ---------------------------
# Node.js
# ---------------------------
node_modules/
dist/
build/
coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# ---------------------------
# Docker
# ---------------------------
.dockerignore
docker-compose.override.yml

# ---------------------------
# Terraform core files
# ---------------------------
**/.terraform/
.terraform/
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.backup
crash.log
crash.*.log

# Provider lock file (optional: many teams KEEP this, but ignoring is fine for personal use)
# .terraform.lock.hcl

