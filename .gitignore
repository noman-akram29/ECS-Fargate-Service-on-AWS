# Terraform variables (may contain secrets)
# ---------------------------
terraform.tfvars
terraform.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# ---------------------------
# CLI / local config
# ---------------------------
.terraformrc
terraform.rc

# ---------------------------
# Logs
# ---------------------------
*.log

# ---------------------------
# OS junk (Windows)
# ---------------------------
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ---------------------------
# IDE / editors
# ---------------------------
.vscode/
.idea/
*.swp
*.swo

# ---------------------------
