# ---------------------------
# Terraform core files
# ---------------------------
.terraform/
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.backup
crash.log
crash.*.log

# Provider lock file (optional: many teams KEEP this, but ignoring is fine for personal use)
.terraform.lock.hcl

# ---------------------------
# Terraform variables (may contain secrets)
# ---------------------------
terraform.tfvars
terraform.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# ---------------------------
# CLI / local config
# ---------------------------
.terraformrc
terraform.rc

# ---------------------------
# Logs
# ---------------------------
*.log

# ---------------------------
# OS junk (Windows)
# ---------------------------
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ---------------------------
# IDE / editors
# ---------------------------
.vscode/
.idea/
*.swp
*.swo

# ---------------------------
# Environment / secrets
# ---------------------------
.env
.env.*